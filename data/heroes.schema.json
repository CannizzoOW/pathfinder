{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Marvel Rivals Heroes",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "role"],
    "properties": {
      "name": {
        "type": "string",
        "description": "Hero display name"
      },
      "role": {
        "type": "string",
        "enum": ["Vanguard", "Duelist", "Strategist"]
      },
      "description": {
        "type": "string"
      }
    },
    "additionalProperties": false
  }
}